# Hermes-Pipeline — Verbindungen und Modelle. Kopieren nach .env und ausfüllen.
# Nur diese Datei anfassen; den Rest rendert der Worker-Entrypoint daraus.

# --- LLM-Server (OpenAI-kompatibel, z. B. Lemonade) --------------------------
HERMES_OPENAI_API_BASE=http://192.168.178.27:13305/api/v1
HERMES_OPENAI_API_KEY=lemonade

# Alternativ Ollama statt OpenAI-kompatibel (dann OPENAI_* leer lassen):
# HERMES_OLLAMA_API_BASE=http://192.168.178.27:11434

# --- Modelle -----------------------------------------------------------------
HERMES_CODER_MODELL=openai/Qwen3-Coder-Next-GGUF
# Reviewer leer = Review bleibt beim Menschen. Gesetzt = Worker reviewt +
# squash-merged automatisch (Bug-Diff-Test-Sieger: Gemma).
HERMES_REVIEWER_MODELL=openai/Gemma-4-31B-it-GGUF

# --- Skeleton-Template-Quelle (Copier) ---------------------------------------
HERMES_TEMPLATE_WEB=gh:max804/skeleton-web

# --- Board-Port auf dem Host (falls 9119 belegt) -----------------------------
HERMES_BOARD_PUBLISH=9119

# --- Poll-Intervall (Sekunden) -----------------------------------------------
HERMES_POLL_S=30

# --- Telegram (optional; leer = nur Logfile) ---------------------------------
HERMES_TELEGRAM_TOKEN=
HERMES_TELEGRAM_CHAT=
