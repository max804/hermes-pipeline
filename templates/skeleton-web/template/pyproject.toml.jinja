[project]
name = "{{ projektname }}"
version = "0.1.0"
description = "{{ beschreibung }}"
requires-python = ">=3.11"
# Erlaubte Bibliotheken sind eine abgeschlossene Liste (BLAUPAUSE.md).
# Änderungen hier sind Architekturentscheidungen, keine Coder-Aufgabe.
dependencies = [
    "fastapi>=0.115",
    "jinja2>=3.1",
    "uvicorn>=0.30",
    "httpx>=0.27",
    "python-multipart>=0.0.9",
]

[project.optional-dependencies]
dev = [
    "pytest>=8",
    "ruff>=0.6",
    "html5lib>=1.1",
]

[build-system]
requires = ["setuptools>=68"]
build-backend = "setuptools.build_meta"

[tool.setuptools.packages.find]
include = ["app*"]

[tool.setuptools.package-data]
app = ["templates/**/*.html", "static/*"]

[tool.pytest.ini_options]
pythonpath = ["."]
testpaths = ["tests"]

[tool.ruff]
line-length = 100
target-version = "py311"
