# make check ist die Definition of Done (ARCHITEKTUR.md §7) — der Worker
# führt es im netzlosen Container aus (Dockerfile.check). Nie umgehen.

.PHONY: check run css deploy

check:
	ruff check app tests
	pytest -q

run:
	uvicorn app.main:app --reload --port {{ port }}

# Tailwind-Standalone-CLI (kein Node im Projekt). Nur nötig nach
# Katalog-Änderungen — die kommen ausschließlich per Skeleton-Change-Karte.
css:
	tailwindcss -i tailwind.input.css -o app/static/theme.css --minify

deploy:
	./deploy.sh
