services:
  {{ projektname }}:
    build: .
    image: {{ projektname }}:latest
    restart: unless-stopped
    ports:
      - "{{ port }}:{{ port }}"
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://127.0.0.1:{{ port }}/healthz')"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s
